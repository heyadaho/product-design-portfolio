---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  class?: string;
}

const { src, alt, caption, class: className } = Astro.props;
---
<figure class:list={['my-8', className]}>
  <img
    src={src}
    alt={alt}
    class="w-full rounded-lg border border-gray-200 shadow-sm"
    width="800"
    height="450"
  />
  {caption && (
    <figcaption class="mt-2 text-center text-sm text-gray-500">
      {caption}
    </figcaption>
  )}
</figure>
