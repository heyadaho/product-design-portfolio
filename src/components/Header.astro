---
const currentPath = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="border-b border-gray-200 bg-surface/95 backdrop-blur supports-[backdrop-filter]:bg-surface/80 dark:border-gray-800 dark:bg-gray-900/95">
  <nav class="mx-auto flex max-w-content items-center justify-between gap-4 px-6 py-4" aria-label="Main">
    <div class="flex items-center gap-4">
      <button
        type="button"
        id="theme-toggle"
        aria-label="Switch to dark mode"
        class="rounded-full p-1.5 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-transform duration-200 active:scale-90"
      >
        <span
          class="block h-5 w-5 rounded-full bg-gray-900 transition-colors duration-300 dark:bg-gray-100"
          aria-hidden="true"
        />
      </button>
      <a href="/" class="text-lg font-semibold text-gray-900 hover:text-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 rounded dark:text-gray-100 dark:hover:text-accent dark:focus:ring-offset-gray-900">Portfolio</a>
    </div>
    <ul class="flex items-center gap-6">
      {nav.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors rounded focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 dark:focus:ring-offset-gray-900',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-accent'
                : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <script>
    (function() {
      var btn = document.getElementById('theme-toggle');
      var html = document.documentElement;
      function setLabel() {
        var isDark = html.classList.contains('dark');
        btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
      }
      function applyTheme(dark) {
        if (dark) {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        } else {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        }
        setLabel();
      }
      btn.addEventListener('click', function() {
        applyTheme(!html.classList.contains('dark'));
      });
      setLabel();
    })();
  </script>
</header>
