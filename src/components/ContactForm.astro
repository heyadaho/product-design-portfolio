---
interface Props {
  /** Formspree or other form endpoint URL. Set PUBLIC_FORMSPREE_ENDPOINT in .env for production. */
  formAction?: string;
}

const { formAction } = Astro.props;
const action = formAction || '';
---
<div class="mt-10" id="contact-form-wrapper">
  <form
    id="contact-form"
    class="space-y-6"
    action={action || '#'}
    method="POST"
    data-animate="fade-in"
    data-form-action={action}
  >
    <input type="hidden" name="_subject" value="Portfolio contact form" />
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 shadow-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 dark:focus:border-accent dark:focus:ring-accent"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 shadow-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 dark:focus:border-accent dark:focus:ring-accent"
      />
    </div>
    <div>
      <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Message</label>
      <textarea
        id="message"
        name="message"
        required
        rows={5}
        class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 shadow-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 dark:focus:border-accent dark:focus:ring-accent"
      />
    </div>
    <div id="form-feedback" class="hidden text-sm" role="status" aria-live="polite" />
    <button
      type="submit"
      id="form-submit"
      class="inline-flex items-center justify-center rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 disabled:opacity-60 dark:focus:ring-offset-gray-900"
    >
      Send message
    </button>
  </form>
</div>
<script>
  (function () {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const feedback = document.getElementById('form-feedback');
    const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
    if (!form || !feedback || !submitBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const action = form.getAttribute('data-form-action') || form.getAttribute('action') || '';
      if (!action || action === '#') {
        feedback.textContent = 'Form endpoint not set. Add PUBLIC_FORMSPREE_ENDPOINT to your environment.';
        feedback.classList.remove('hidden', 'text-green-600', 'dark:text-green-400');
        feedback.classList.add('text-amber-600', 'dark:text-amber-400');
        return;
      }

      feedback.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      const formData = new FormData(form);

      try {
        const res = await fetch(action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok && !data.error) {
          feedback.textContent = 'Thanks — your message has been sent.';
          feedback.classList.remove('hidden', 'text-red-600', 'dark:text-red-400');
          feedback.classList.add('text-green-600', 'dark:text-green-400');
          form.reset();
        } else {
          feedback.textContent = data.error || 'Something went wrong. Please try again or email directly.';
          feedback.classList.remove('hidden', 'text-green-600', 'dark:text-green-400');
          feedback.classList.add('text-red-600', 'dark:text-red-400');
        }
      } catch {
        feedback.textContent = 'Could not send. Please try emailing directly.';
        feedback.classList.remove('hidden', 'text-green-600', 'dark:text-green-400');
        feedback.classList.add('text-red-600', 'dark:text-red-400');
      }

      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message';
    });
  })();
</script>
