---
const links = [
  { href: '/contact', label: 'Contact' },
  { href: 'https://www.linkedin.com/in/edwardcellanlake/', label: 'LinkedIn', external: true },
];
---
<footer class="border-t border-gray-200 bg-surface mt-auto dark:border-border dark:bg-card">
  <div class="mx-auto max-w-content px-6 py-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-gray-500 dark:text-gray-400">© {new Date().getFullYear()} Ed Lake</p>
      <ul class="flex items-center gap-6">
        {links.map(({ href, label, external }) => (
          <li>
            <a
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              class="text-sm text-gray-500 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 rounded dark:text-gray-400 dark:hover:text-gray-200 dark:focus:ring-offset-background"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
