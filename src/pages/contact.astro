---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';

const socials = [
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/edwardcellanlake/',
    icon: '<path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/>',
  },
  {
    name: 'Medium',
    href: 'https://medium.com/@edlakedesign',
    icon: '<path fill="currentColor" d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>',
  },
  {
    name: 'Dribbble',
    href: 'https://dribbble.com/edlakedesign',
    icon: '<path fill="currentColor" d="M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.11-3.17-.953-6.384-.438 1.34 3.684 1.797 6.684 1.97 7.308 2.316-1.555 3.936-4.02 4.395-6.87zm-6.115 7.808c-.153-.9-.75-4.032-2.19-7.77l-.066.02c-5.79 2.015-7.86 6.025-8.04 6.4 1.73 1.358 3.92 2.166 6.29 2.166 1.42 0 2.77-.29 4-.814zm-11.62-2.58c.24-.4 2.37-3.97 5.5-6.027.026-.02.05-.04.076-.058C6.726 4.585 3.34 8.01 1.385 11.87zm1.197-.36c1.52-2.75 4.35-5.59 7.19-6.156.12-.024.24-.045.36-.063-1.1-2.06-2.35-3.66-3.68-4.66-2.86 1.24-5.04 3.87-5.87 6.885zM12 1.608c-1.13 0-2.21.2-3.23.56 1.38 1.16 2.65 2.68 3.68 4.66.12.018.24.04.36.063 2.84.566 5.67 3.406 7.19 6.156.18-.36.35-.73.5-1.11-1.63-4.66-5.94-8.33-8.5-10.335zm-3.32 1.01c-1.33 1-2.58 2.6-3.68 4.66 2.86 1.24 5.04 3.87 5.87 6.885.52-1.17 1.2-2.26 2.04-3.23-.66-.25-1.31-.48-1.97-.68-.18-.07-.36-.13-.54-.2.02-.14.04-.28.06-.43z"/>',
  },
];
---
<Layout title="Contact" description="Get in touch — product designer portfolio.">
  <Section class="pt-16 md:pt-24">
    <div class="mx-auto max-w-prose">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl dark:text-gray-100" data-animate="fade-in">
        Contact
      </h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400" data-animate="fade-in">
        Reach out for projects, design chats, or collaboration—I’d love to hear from you.
      </p>

      <div class="mt-10" data-animate="fade-in">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">
          Prefer to connect elsewhere? Find me here:
        </p>
        <ul class="mt-4 flex flex-wrap items-center gap-6" aria-label="Social links">
          {socials.map(({ name, href, icon }) => (
            <li>
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 text-gray-600 transition-colors hover:text-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 rounded dark:text-gray-400 dark:hover:text-accent dark:focus:ring-offset-background"
                aria-label={name}
              >
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-700" aria-hidden="true">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" set:html={icon} />
                </span>
                <span class="text-sm font-medium">{name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <hr class="my-12 border-gray-200 dark:border-gray-700" aria-hidden="true" />

      <p class="text-sm font-medium text-gray-500 dark:text-gray-400" data-animate="fade-in">
        Or drop me a line below—I usually reply within a day or two.
      </p>
      <ContactForm formAction={import.meta.env.PUBLIC_FORMSPREE_ENDPOINT} />
    </div>
  </Section>
</Layout>
